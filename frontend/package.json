{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prisma:generate": "prisma generate --schema ../backend/prisma/schema.prisma --generator client_frontend",
    "postinstall": "npm run prisma:generate",
    "dev": "npm run prisma:generate; next dev --webpack",
    "dev:lowmem": "npm run prisma:generate; set NODE_OPTIONS=--max-old-space-size=2048&& next dev --webpack",
    "build": "npm run prisma:generate; next build --webpack",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@prisma/extension-accelerate": "^3.0.1",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-auth": "^4.24.13",
    "react": "19.2.4",
    "react-calendar": "^6.0.1",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-calendar": "^3.9.0",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "postcss": "^8.5.9",
    "prisma": "^7.7.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5"
  }
}
