# Root-level ignores for full-repo pushes

# Dependencies
**/node_modules/

# Build outputs
**/dist/
**/.next/
**/out/
**/build/
**/coverage/

# TypeScript
**/*.tsbuildinfo

# Environment files (keep secrets out of git)
**/.env
**/.env.*
!**/.env.example

# Logs
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# OS/editor noise
**/.DS_Store
**/Thumbs.db

# Vercel
**/.vercel/

# Prisma generated client in backend source
backend/src/generated/prisma/
