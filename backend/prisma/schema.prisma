
generator client {
  provider = "prisma-client-js"
}

generator client_frontend {
  provider = "prisma-client-js"
  output   = "../../frontend/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                 String  @id @default(uuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  
  timezone      String    @default("Asia/Kolkata")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts      Account[]
  sessions      Session[]
  eventTypes    EventType[]
  availability  Availability[]
  dateOverrides DateOverride[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model EventType {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  name             String
  slug             String   @unique
  description      String?
  durationMins     Int      @map("duration_mins")
  color            String   @default("#0069ff")
  isActive         Boolean  @default(true) @map("is_active")
  bufferBeforeMins Int      @default(0) @map("buffer_before_mins")
  bufferAfterMins  Int      @default(0) @map("buffer_after_mins")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([slug])
  @@map("event_types")
}

model Availability {
  id        String  @id @default(uuid())
  userId    String  @map("user_id")
  dayOfWeek Int     @map("day_of_week") // 0=Sun
  isEnabled Boolean @default(true) @map("is_enabled")
  startTime String  @map("start_time")
  endTime   String  @map("end_time")

  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  windows AvailabilityWindow[]

  @@unique([userId, dayOfWeek])
  @@map("availability")
}

model AvailabilityWindow {
  id             String @id @default(uuid())
  availabilityId String @map("availability_id")
  startTime      String @map("start_time")
  endTime        String @map("end_time")
  sortOrder      Int    @default(0) @map("sort_order")

  availability Availability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)

  @@index([availabilityId])
  @@map("availability_windows")
}

model Booking {
  id            String   @id @default(uuid())
  eventTypeId   String   @map("event_type_id")
  inviteeName   String   @map("invitee_name")
  inviteeEmail  String   @map("invitee_email")
  startTime     DateTime @map("start_time")
  endTime       DateTime @map("end_time")
  timezone      String   @default("Asia/Kolkata")
  status        String   @default("confirmed")
  cancelToken   String   @unique @default(uuid()) @map("cancel_token")
  googleEventId String?  @map("google_event_id") // Maps to Google Calendar event
  meetingUrl    String?  @map("meeting_url")     // Google Meet URL
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  eventType EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)

  @@index([eventTypeId, startTime])
  @@map("bookings")
}

model DateOverride {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  date      DateTime @db.Date
  isBlocked Boolean  @default(false) @map("is_blocked")
  startTime String?  @map("start_time")
  endTime   String?  @map("end_time")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("date_overrides")
}
